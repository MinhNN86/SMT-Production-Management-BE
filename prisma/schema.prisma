generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id          Int          @id @default(autoincrement())
  teamName    String       @map("team_name") @db.VarChar(100)
  description String?
  members     TeamMember[]

  @@map("teams")
}

model TeamMember {
  id       Int    @id @default(autoincrement())
  teamId   Int    @map("team_id")
  workerId String @map("worker_id") @db.Uuid
  joinedAt DateTime? @default(now()) @map("joined_at") @db.Timestamp(6)
  team     Team   @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_team_members_team")
  worker   User   @relation(fields: [workerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_team_members_worker")

  @@unique([teamId, workerId], map: "unique_team_member")
  @@map("team_members")
}

model DeviceType {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(100)
  description      String?
  productionOrders ProductionOrder[]
  stageDeviceTypes StageDeviceType[]

  @@map("device_types")
}

model ProductionOrder {
  id                  Int                    @id @default(autoincrement())
  orderCode           String                 @unique @map("order_code") @db.VarChar(50)
  totalQuantity       Int                    @map("total_quantity")
  orderSignedDate     DateTime?              @map("order_signed_date") @db.Date
  productionStartDate DateTime?              @map("production_start_date") @db.Date
  completedDate       DateTime?              @map("completed_date") @db.Date
  deadlineDate        DateTime?              @map("deadline_date") @db.Date
  status              ProductionOrderStatus? @default(PENDING)
  createdAt           DateTime?              @default(now()) @map("created_at") @db.Timestamp(6)
  deviceTypeId        Int?                   @map("device_type_id")
  productionLogs      ProductionLog[]
  deviceType          DeviceType?            @relation(fields: [deviceTypeId], references: [id], onUpdate: NoAction, map: "fk_production_orders_device_type")
  workAssignments     WorkAssignment[]
  backupStages        BackupStage[]

  @@index([deviceTypeId], map: "idx_production_orders_device_type_id")
  @@map("production_orders")
}

model Stage {
  id               Int                   @id @default(autoincrement())
  name             String                @db.VarChar(255)
  displayOrder     Int                   @default(0) @map("display_order")
  description      String?
  productionLogs   ProductionLog[]
  stageDeviceTypes StageDeviceType[]
  parentLink       StageHierarchy?       @relation("StageHierarchyChild")
  childLinks       StageHierarchy[]      @relation("StageHierarchyParent")
  workloadConfigs  StageWorkloadConfig[]
  workAssignments  WorkAssignment[]
  backupStages     BackupStage[]

  @@map("stages")
}

model BackupStage {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(255)
  orderId        Int              @map("order_id")
  displayOrder   Int              @default(0) @map("display_order")
  description    String?
  parentStageId  Int?             @map("parent_stage_id")
  createdAt      DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  productionOrder ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_backup_stages_order")
  parentStage    Stage?           @relation(fields: [parentStageId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_backup_stages_parent_stage")
  workAssignments WorkAssignment[]
  productionLogs  ProductionLog[]

  @@index([orderId], map: "idx_backup_stages_order_id")
  @@index([parentStageId], map: "idx_backup_stages_parent_stage_id")
  @@map("backup_stages")
}

model Shift {
  id              Int              @id @default(autoincrement())
  shiftName       String           @map("shift_name") @db.VarChar(50)
  startTime       DateTime?        @map("start_time") @db.Time(6)
  endTime         DateTime?        @map("end_time") @db.Time(6)
  productionLogs  ProductionLog[]
  workAssignments WorkAssignment[]

  @@map("shifts")
}

model StageWorkloadConfig {
  id             Int   @id @default(autoincrement())
  stageId        Int   @map("stage_id")
  numWorkers     Int   @map("num_workers")
  targetQuantity Int   @map("target_quantity")
  timeHours      Float @map("time_hours")
  stage          Stage @relation(fields: [stageId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_stage_workload_stage")

  @@map("stage_workload_configs")
}

model User {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  workerCode      String           @unique @map("worker_code") @db.VarChar(50)
  fullName        String           @map("full_name") @db.VarChar(255)
  type            WorkerType?
  email           String?          @unique @db.VarChar(255)
  password        String?          @db.VarChar(255)
  role            UserRole?        @default(USER)
  teamMemberships TeamMember[]
  workAssignments WorkAssignment[]

  @@map("users")
}

model WorkAssignment {
  id                Int             @id @default(autoincrement())
  productionOrderId Int             @map("production_order_id")
  stageId           Int?            @map("stage_id")
  backupStageId     Int?            @map("backup_stage_id")
  shiftId           Int             @map("shift_id")
  workerId          String          @map("worker_id") @db.Uuid
  workDate          DateTime        @map("work_date") @db.Date
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wa_production_order")
  stage             Stage?          @relation(fields: [stageId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wa_stage")
  backupStage       BackupStage?    @relation(fields: [backupStageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_wa_backup_stage")
  shift             Shift           @relation(fields: [shiftId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wa_shift")
  worker            User            @relation(fields: [workerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_wa_worker")

  @@unique([workerId, workDate, shiftId], map: "unique_worker_shift")
  @@index([backupStageId], map: "idx_work_assignments_backup_stage_id")
  @@map("work_assignments")
}

model ProductionLog {
  id                Int             @id @default(autoincrement())
  productionOrderId Int             @map("production_order_id")
  stageId           Int?            @map("stage_id")
  backupStageId     Int?            @map("backup_stage_id")
  shiftId           Int             @map("shift_id")
  logDate           DateTime        @map("log_date") @db.Date
  actualQuantity    Int             @default(0) @map("actual_quantity")
  defectiveQuantity Int             @default(0) @map("defective_quantity")
  note              String?
  createdAt         DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pl_production_order")
  shift             Shift           @relation(fields: [shiftId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pl_shift")
  stage             Stage?          @relation(fields: [stageId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pl_stage")
  backupStage       BackupStage?    @relation(fields: [backupStageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pl_backup_stage")

  @@unique([productionOrderId, stageId, shiftId, logDate], map: "unique_production_log_stage")
  @@unique([productionOrderId, backupStageId, shiftId, logDate], map: "unique_production_log_backup_stage")
  @@map("production_logs")
}

model StageDeviceType {
  stageId      Int        @map("stage_id")
  deviceTypeId Int        @map("device_type_id")
  deviceType   DeviceType @relation(fields: [deviceTypeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stage_device_types_device_type")
  stage        Stage      @relation(fields: [stageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stage_device_types_stage")

  @@id([stageId, deviceTypeId], map: "pk_stage_device_types")
  @@index([deviceTypeId], map: "idx_stage_device_types_device_type_id")
  @@map("stage_device_types")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model StageHierarchy {
  childStageId  Int   @id @map("child_stage_id")
  parentStageId Int   @map("parent_stage_id")
  childStage    Stage @relation("StageHierarchyChild", fields: [childStageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stage_hierarchy_child")
  parentStage   Stage @relation("StageHierarchyParent", fields: [parentStageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stage_hierarchy_parent")

  @@index([parentStageId], map: "idx_stage_hierarchy_parent_stage_id")
  @@map("stage_hierarchy")
}

enum ProductionOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED

  @@map("production_orders_status_enum")
}

enum WorkerType {
  PARTTIME
  FULLTIME

  @@map("type_workers_enum")
}

enum UserRole {
  SYSTEM_ADMIN
  ADMIN
  USER

  @@map("user_role_enum")
}
